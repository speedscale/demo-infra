{
  "id": "banking-app-keys",
  "redactlist": {
    "entries": {
      "all": [
        "plaid-client-id",
        "plaid-secret",
        "hibp-api-key",
        "x-api-key",
        "socureapikey"
      ]
    }
  },
  "discoverPatterns": false,
  "transforms": [
    {
      "filters": {
        "filters": [
          {
            "include": true,
            "direction": "OUT"
          }
        ]
      },
      "extractor": {
        "type": "req_body"
      },
      "transforms": [
        {
          "type": "json_path",
          "config": {
            "path": "$api_key"
          }
        },
        {
          "type": "dlp_field"
        }
      ]
    },
    {
      "filters": {
        "filters": [
          {
            "include": true,
            "direction": "OUT"
          }
        ]
      },
      "extractor": {
        "type": "http_queryparam",
        "config": {
          "name": "app_id"
        }
      },
      "transforms": [
        {
          "type": "dlp_field"
        }
      ]
    },
    {
      "filters": {
        "filters": [
          {
            "include": true,
            "direction": "IN"
          }
        ]
      },
      "extractor": {
        "type": "json_path",
        "config": {
          "path": "http.req.headers.Authorization.0.jwt.claims.sub",
          "regex": "^(?i)Bearer (.*)(?-i)"
        }
      },
      "transforms": [
        {
          "type": "tag_session"
        }
      ]
    },
    {
      "filters": {
        "filters": [
          {
            "include": true,
            "direction": "OUT"
          }
        ]
      },
      "extractor": {
        "type": "http_queryparam",
        "config": {
          "name": "key"
        }
      },
      "transforms": [
        {
          "type": "dlp_field"
        }
      ]
    },
    {
      "filters": {
        "filters": [
          {
            "include": true,
            "direction": "OUT"
          },
          {
            "operator": "REGEX",
            "network_address": "(^banking-|\\.svc|localhost|127\\.0\\.0\\.1)"
          }
        ]
      },
      "extractor": {
        "type": "http_req_header",
        "config": {
          "name": "Authorization"
        }
      },
      "transforms": [
        {
          "type": "split",
          "config": {
            "index": "1",
            "separator": " "
          }
        },
        {
          "type": "base64"
        },
        {
          "type": "dlp_field"
        }
      ]
    }
  ]
}
